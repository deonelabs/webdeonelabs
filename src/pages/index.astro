---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DeOne Labs — Páginas web, bots de WhatsApp con IA y más para tu negocio</title>
    <meta
      name="description"
      content="Páginas web todo incluido desde $390.000, bots de WhatsApp con inteligencia artificial, correo corporativo y automatizaciones para pymes en Colombia. Sin costos escondidos."
    />
    <meta name="theme-color" content="#FBDE5B" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23FBDE5B'/><text x='50' y='69' font-family='Arial, sans-serif' font-size='44' font-weight='900' text-anchor='middle' fill='%230B0B0B'>DO</text></svg>" />
  </head>
  <body class="min-h-screen antialiased">
    <!-- Cortina de entrada con la imagen de marca -->
    <div id="curtain" aria-hidden="true">
      <div class="curtain-panel curtain-left"></div>
      <div class="curtain-panel curtain-right"></div>
      <div class="curtain-content px-6 text-center">
        <p class="font-heading text-7xl leading-none tracking-tight text-ink md:text-8xl">DO</p>
        <p class="mt-1 text-[0.65rem] font-extrabold tracking-[0.4em] text-ink md:text-xs">DE ONE</p>
        <p
          class="mx-auto mt-10 max-w-md text-2xl font-medium leading-snug text-ink/90 md:text-3xl"
          data-es-html="Aquí pasamos de&lt;br /&gt;pensarlo… a, la"
          data-en-html="Here we go from&lt;br /&gt;thinking it… to"
          set:html="Aquí pasamos de<br />pensarlo… a, la"
        />
        <p class="mt-4 font-heading text-4xl uppercase tracking-tight text-ink md:text-5xl" data-es="Acción" data-en="Action">Acción</p>
        <p class="mt-6 text-sm text-ink/80 md:text-base" data-es="(lo único que hará tus sueños realidad)" data-en="(the only thing that will make your dreams real)">(lo único que hará tus sueños realidad)</p>
      </div>
    </div>

    <!-- Nav: barra plana amarilla con borde negro -->
    <header id="site-header" class="fixed inset-x-0 top-0 z-50">
      <nav
        id="site-nav"
        class="grid grid-cols-[auto_1fr_auto] items-center gap-3 border-b-4 border-ink bg-brand px-4 md:grid-cols-3 md:px-8"
        aria-label="Principal"
      >
        <a href="#" class="flex items-center gap-2.5 justify-self-start">
          <span class="grid h-9 w-9 place-items-center bg-ink font-heading text-sm text-brand" aria-hidden="true">DO</span>
          <span class="font-heading text-lg uppercase tracking-wide text-ink">DeOne Labs</span>
        </a>
        <div class="hidden items-center justify-center gap-8 text-xs font-extrabold uppercase tracking-widest text-ink md:flex">
          <a href="#servicios" class="nav-link" data-es="Servicios" data-en="Services">Servicios</a>
          <a href="#bot" class="nav-link" data-es="Bot con IA" data-en="AI Bot">Bot con IA</a>
          <a href="#portafolio" class="nav-link" data-es="Portafolio" data-en="Portfolio">Portafolio</a>
          <a href="#preguntas" class="nav-link" data-es="Preguntas" data-en="FAQ">Preguntas</a>
        </div>
        <div class="flex items-center gap-2 justify-self-end">
          <button
            id="lang-toggle"
            type="button"
            class="btn btn-ripple grid h-9 w-9 place-items-center rounded-full border-2 border-ink bg-white text-[0.65rem] font-extrabold uppercase text-ink"
            aria-label="Cambiar idioma / Switch language"
            title="Español / English"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d={iconPaths.globe} /></svg>
            <span class="sr-only" data-lang-label>ES</span>
          </button>
          <button
            id="currency-toggle"
            type="button"
            class="btn btn-ripple grid h-9 place-items-center rounded-full border-2 border-ink bg-white px-2.5 text-[0.65rem] font-extrabold uppercase text-ink"
            aria-label="Cambiar moneda / Switch currency"
            title="COP / USD"
          >
            <span data-currency-label>COP</span>
          </button>
          <a
            href={wa('Hola DeOne Labs, quiero información sobre sus servicios')}
            class="btn btn-dark btn-ripple rounded-full bg-ink px-5 py-2.5 text-sm font-bold text-white"
            target="_blank"
            rel="noopener"
            data-es="Escríbenos"
            data-en="Message us"
          >
            Escríbenos
          </a>
        </div>
      </nav>
    </header>

    <!-- Hero: bloque amarillo -->
    <section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-brand px-4 pb-20 pt-36">
      <!-- Líneas decorativas -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <svg class="absolute inset-0 hidden h-full w-full lg:block" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
          <path d="M120 300 C 320 180, 520 220, 720 300 S 1150 380, 1330 260" stroke="#0B0B0B" stroke-opacity="0.12" stroke-width="2" />
          <path class="animate-dash" d="M180 620 C 420 700, 760 560, 1000 640 S 1280 700, 1380 620" stroke="#0B0B0B" stroke-opacity="0.35" stroke-width="2" stroke-dasharray="8 10" />
          <path class="animate-dash" d="M100 260 C 360 340, 680 200, 980 280 S 1300 340, 1400 300" stroke="#FFFFFF" stroke-opacity="0.8" stroke-width="2" stroke-dasharray="4 12" style="animation-delay:-6s" />
        </svg>
      </div>

      <!-- Tarjetas flotantes con parallax -->
      <div class="pointer-events-none absolute left-[7%] top-[27%] hidden lg:block" data-depth="26" aria-hidden="true">
        <div class="animate-float" style="--r:-6deg">
          <div class="grid h-16 w-16 place-items-center border-4 border-ink bg-white">
            <svg class="h-7 w-7 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.bolt} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute right-[8%] top-[24%] hidden lg:block" data-depth="38" aria-hidden="true">
        <div class="animate-float" style="--r:5deg; --fd:-2s">
          <div class="grid h-16 w-16 place-items-center bg-ink">
            <svg class="h-7 w-7 text-yellow" viewBox="0 0 24 24" fill="currentColor"><path d={iconPaths.whatsapp} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute bottom-[20%] left-[13%] hidden lg:block" data-depth="18" aria-hidden="true">
        <div class="animate-float" style="--r:4deg; --fd:-4s">
          <div class="grid h-14 w-14 place-items-center border-4 border-ink bg-white">
            <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.mail} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute bottom-[26%] right-[11%] hidden lg:block" data-depth="30" aria-hidden="true">
        <div class="animate-float" style="--r:-4deg; --fd:-5s">
          <div class="grid h-14 w-14 place-items-center border-4 border-ink bg-white">
            <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.cart} /></svg>
          </div>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-6xl text-center">
        <p class="reveal mb-8 inline-flex items-center gap-2 border-2 border-ink bg-white px-4 py-1.5 text-xs font-extrabold uppercase tracking-wider text-ink">
          <span class="inline-block h-2 w-2 animate-pulse bg-ink" aria-hidden="true"></span>
          <span
            data-es="Promo de lanzamiento: precio especial para los primeros 10 clientes"
            data-en="Launch promo: special price for the first 10 clients"
          >Promo de lanzamiento: precio especial para los primeros 10 clientes</span>
        </p>
        <h1 class="reveal mx-auto max-w-5xl text-5xl uppercase leading-[0.95] text-ink sm:text-7xl md:text-8xl" style="--d:.1s">
          <span data-es="Tu negocio en internet," data-en="Your business online,">Tu negocio en internet,</span>
          <span class="inline-block bg-ink px-3 text-brand" data-es="todo incluido" data-en="all inclusive">todo incluido</span><span data-es=", sin letra pequeña" data-en=", no fine print">, sin letra pequeña</span>
        </h1>
        <p class="reveal mx-auto mt-8 max-w-2xl text-lg font-medium leading-relaxed text-ink/80" style="--d:.2s">
          <span data-es="Páginas web desde" data-en="Websites starting at">Páginas web desde</span>
          <strong class="text-ink" data-cop={servicios[0].precioDisplayCOP} data-usd={servicios[0].precioDisplayUSD}>{servicios[0].precioDisplayCOP}</strong><span
            data-es=", bots de WhatsApp con inteligencia artificial que venden por ti 24/7, correo corporativo y automatizaciones. Dominio, hosting, SSL y soporte"
            data-en=", AI-powered WhatsApp bots that sell for you 24/7, corporate email and automations. Domain, hosting, SSL and support"
          >, bots de WhatsApp con inteligencia artificial que venden por ti 24/7, correo corporativo y automatizaciones. Dominio, hosting, SSL y soporte</span>
          <strong class="text-ink" data-es="incluidos en un solo precio" data-en="included in a single price">incluidos en un solo precio</strong>.
        </p>
        <div class="reveal mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" style="--d:.3s">
          <a
            href={wa('Hola DeOne Labs, quiero cotizar mi página web')}
