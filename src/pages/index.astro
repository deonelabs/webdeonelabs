---
import '../styles/global.css';

// TODO: cambiar al número comercial definitivo de DeOne Labs
const WHATSAPP = '573108870800';
const wa = (msg) => `https://wa.me/${WHATSAPP}?text=${encodeURIComponent(msg)}`;

const servicios = [
  {
    nombre: 'Landing Express',
    desc: 'Tu negocio con página propia en una semana. Hasta 5 secciones, lista para vender.',
    precio: '$390.000',
    mes: '$39.000/mes',
    mercado: 'Otros cobran $500.000 – $1.200.000 + hosting aparte',
    incluye: ['Dominio .com y SSL incluidos', 'Hosting y soporte incluidos', '1 cambio de contenido al mes', 'Entrega en 5–7 días'],
    icon: 'bolt',
  },
  {
    nombre: 'Web Corporativa',
    desc: 'Sitio completo de 5 a 8 páginas para empresas que quieren verse serias en internet.',
    precio: '$990.000',
    mes: '$59.000/mes',
    mercado: 'Otros cobran $2.500.000 – $6.000.000',
    incluye: ['5–8 páginas + blog', 'SEO básico para Google', 'Correo de contacto', 'Dominio, SSL y hosting incluidos'],
    icon: 'building',
  },
  {
    nombre: 'Tienda Online',
    desc: 'Vende por internet con pagos en línea: Wompi, MercadoPago o contraentrega.',
    precio: '$1.690.000',
    mes: '$129.000/mes',
    mercado: 'Otros cobran $1.800.000 – $15.000.000',
    incluye: ['Hasta 100 productos', 'Pasarela de pagos colombiana', 'Panel para administrar tú mismo', 'Capacitación incluida'],
    icon: 'cart',
  },
  {
    nombre: 'Correo Corporativo',
    desc: 'Deja de escribir desde @gmail.com: correo con el nombre de tu empresa.',
    precio: 'Sin costo de instalación',
    mes: '$20.000/usuario/mes',
    mercado: 'Google Workspace cuesta ~$27.000',
    incluye: ['tunombre@tuempresa.com', '50 GB por buzón', 'Webmail + celular', 'Migración incluida'],
    icon: 'mail',
  },
  {
    nombre: 'Automatizaciones',
    desc: 'Que el sistema trabaje por ti: pedidos, recordatorios y reportes automáticos.',
    precio: '$350.000/flujo',
    mes: '$49.000/mes',
    mercado: 'Por fuera se cotiza en $1.000.000+',
    incluye: ['Pedidos → WhatsApp', 'Recordatorios de citas', 'Reportes a Excel automáticos', 'A tu medida'],
    icon: 'gears',
  },
  {
    nombre: 'Pack Emprendedor',
    desc: 'Todo lo que necesita un negocio que arranca: página + correo + bot de WhatsApp.',
    precio: '$1.590.000',
    mes: '$189.000/mes',
    mercado: 'Por separado: $1.880.000 + $258.000/mes',
    incluye: ['Landing Express completa', '2 correos corporativos', 'Bot de WhatsApp básico', 'Ahorra $290.000 + $69.000/mes'],
    icon: 'rocket',
    destacado: true,
  },
];

const chat = [
  { from: 'cliente', text: '¿Tienen pintura blanca tipo 1? ¿A cómo el galón?' },
  { from: 'bot', text: '¡Hola! 👋 Sí tenemos. El galón tipo 1 está a $68.000 y el garrafón a $198.000. ¿Te lo aparto o te lo enviamos a domicilio?' },
  { from: 'cliente', text: 'A domicilio, estoy en el barrio Centro' },
  { from: 'bot', text: 'Perfecto ✅ Domicilio al Centro: $5.000, llega hoy antes de las 5pm. Me confirmas nombre y dirección y queda pedido.' },
];

const faqs = [
  {
    q: '¿Por qué tan barato comparado con otras agencias?',
    a: 'Porque nuestra infraestructura es propia y ultraeficiente, y trabajamos con plantillas profesionales que personalizamos para ti. No pagas oficinas ni intermediarios: pagas el trabajo y ya.',
  },
  {
    q: '¿Qué incluye la mensualidad?',
    a: 'Hosting, dominio, certificado de seguridad (SSL), copias de seguridad, soporte por WhatsApp y cambios menores de contenido. Un solo pago, sin sorpresas.',
  },
  {
    q: '¿Y si no me gusta el diseño?',
    a: 'Te devolvemos la plata. Así de simple. Primero te mostramos el diseño, lo ajustamos contigo y solo pagas el saldo cuando estés feliz con el resultado.',
  },
  {
    q: '¿El bot de WhatsApp usa mi mismo número?',
    a: 'Sí. El bot atiende desde tu número de WhatsApp, con tu nombre y tu logo. Tú sigues pudiendo entrar a la conversación cuando quieras.',
  },
  {
    q: '¿Hay permanencia mínima?',
    a: 'No. Si un mes decides no seguir, no sigues. Tu dominio es tuyo y te lo entregamos.',
  },
];

const iconPaths = {
  bolt: 'M13 10V3L4 14h7v7l9-11h-7z',
  building:
    'M3 21h18M5 21V5a2 2 0 012-2h10a2 2 0 012 2v16M9 8h1m4 0h1M9 12h1m4 0h1M9 16h1m4 0h1',
  cart: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.3 2.3c-.6.6-.2 1.7.7 1.7H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  mail: 'M3 8l7.9 5.3a2 2 0 002.2 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  gears:
    'M10.3 4.3a1.7 1.7 0 013.4 0 1.7 1.7 0 002.6 1.1 1.7 1.7 0 012.4 2.4 1.7 1.7 0 001 2.5 1.7 1.7 0 010 3.4 1.7 1.7 0 00-1 2.5 1.7 1.7 0 01-2.4 2.4 1.7 1.7 0 00-2.6 1 1.7 1.7 0 01-3.4 0 1.7 1.7 0 00-2.6-1 1.7 1.7 0 01-2.4-2.4 1.7 1.7 0 00-1-2.5 1.7 1.7 0 010-3.4 1.7 1.7 0 001-2.5 1.7 1.7 0 012.4-2.4 1.7 1.7 0 002.6-1.1zM15 12a3 3 0 11-6 0 3 3 0 016 0z',
  rocket:
    'M15.6 3.4c1.9-.6 3.7-.6 5 0 .6 1.3.6 3.1 0 5-1 2.7-3.2 5.6-6.6 7.7l-3.1 3.1a1 1 0 01-1.6-.3l-1.5-3.3-3.3-1.5a1 1 0 01-.3-1.6l3.1-3.1c2.1-3.4 5-5.6 7.7-6.6zM6 15l-2 5 5-2m6-7a1.5 1.5 0 100-3 1.5 1.5 0 000 3z',
  check: 'M5 13l4 4L19 7',
  arrow: 'M5 12h14m-6-6 6 6-6 6',
  whatsapp:
    'M12 2a10 10 0 00-8.6 15.1L2 22l5-1.3A10 10 0 1012 2zm4.8 13.9c-.2.6-1.2 1.1-1.7 1.2-.4 0-1 .2-3.3-.7-2.8-1.1-4.6-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.9s.7-2 1-2.3c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.9 2.1c0 .2.1.4 0 .6l-.4.6-.5.5c-.2.2-.3.4-.1.7.2.3.8 1.4 1.8 2.2 1.2 1.1 2.3 1.5 2.6 1.6.3.1.5.1.7-.1l1-1.2c.2-.3.4-.2.7-.1l2.1 1c.3.2.5.3.6.4 0 .1 0 .8-.4 1.4z',
  phone:
    'M3 5.5A2.5 2.5 0 015.5 3h1.6a1 1 0 01.95.68l1.1 3.3a1 1 0 01-.25 1.03l-1.36 1.36a12.5 12.5 0 006.09 6.09l1.36-1.36a1 1 0 011.03-.25l3.3 1.1a1 1 0 01.68.95v1.6A2.5 2.5 0 0118.5 21 15.5 15.5 0 013 5.5z',
  video: 'M23 7l-7 5 7 5V7zM14 5H3a2 2 0 00-2 2v10a2 2 0 002 2h11a2 2 0 002-2V7a2 2 0 00-2-2z',
  mic: 'M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zM19 10v2a7 7 0 01-14 0v-2M12 19v4',
  plus: 'M12 5v14M5 12h14',
  dots: 'M12 5h.01M12 12h.01M12 19h.01',
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DeOne Labs — Páginas web, bots de WhatsApp con IA y más para tu negocio</title>
    <meta
      name="description"
      content="Páginas web todo incluido desde $390.000, bots de WhatsApp con inteligencia artificial, correo corporativo y automatizaciones para pymes en Colombia. Sin costos escondidos."
    />
    <meta name="theme-color" content="#FBDE5B" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23FBDE5B'/><text x='50' y='69' font-family='Arial, sans-serif' font-size='44' font-weight='900' text-anchor='middle' fill='%230B0B0B'>DO</text></svg>" />
  </head>
  <body class="min-h-screen antialiased">
    <!-- Cortina de entrada con la imagen de marca -->
    <div id="curtain" aria-hidden="true">
      <div class="curtain-panel curtain-left"></div>
      <div class="curtain-panel curtain-right"></div>
      <div class="curtain-content px-6 text-center">
        <p class="font-heading text-7xl leading-none tracking-tight text-ink md:text-8xl">DO</p>
        <p class="mt-1 text-[0.65rem] font-extrabold tracking-[0.4em] text-ink md:text-xs">DE ONE</p>
        <p class="mx-auto mt-10 max-w-md text-2xl font-medium leading-snug text-ink/90 md:text-3xl">
          Aquí pasamos de<br />pensarlo… a, la
        </p>
        <p class="mt-4 font-heading text-4xl uppercase tracking-tight text-ink md:text-5xl">Acción</p>
        <p class="mt-6 text-sm text-ink/80 md:text-base">(lo único que hará tus sueños realidad)</p>
      </div>
    </div>

    <!-- Nav: barra plana amarilla con borde negro -->
    <header id="site-header" class="fixed inset-x-0 top-0 z-50">
      <nav
        id="site-nav"
        class="grid grid-cols-[auto_1fr_auto] items-center gap-4 border-b-4 border-ink bg-brand px-4 md:grid-cols-3 md:px-8"
        aria-label="Principal"
      >
        <a href="#" class="flex items-center gap-2.5 justify-self-start">
          <span class="grid h-9 w-9 place-items-center bg-ink font-heading text-sm text-brand" aria-hidden="true">DO</span>
          <span class="font-heading text-lg uppercase tracking-wide text-ink">DeOne Labs</span>
        </a>
        <div class="hidden items-center justify-center gap-8 text-xs font-extrabold uppercase tracking-widest text-ink md:flex">
          <a href="#servicios" class="nav-link">Servicios</a>
          <a href="#bot" class="nav-link">Bot con IA</a>
          <a href="#portafolio" class="nav-link">Portafolio</a>
          <a href="#preguntas" class="nav-link">Preguntas</a>
        </div>
        <a
          href={wa('Hola DeOne Labs, quiero información sobre sus servicios')}
          class="btn btn-dark btn-ripple justify-self-end rounded-full bg-ink px-5 py-2.5 text-sm font-bold text-white"
          target="_blank"
          rel="noopener"
        >
          Escríbenos
        </a>
      </nav>
    </header>

    <!-- Hero: bloque amarillo -->
    <section id="hero" class="relative flex min-h-screen items-center overflow-hidden bg-brand px-4 pb-20 pt-36">
      <!-- Líneas decorativas -->
      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <svg class="absolute inset-0 hidden h-full w-full lg:block" viewBox="0 0 1440 900" fill="none" preserveAspectRatio="xMidYMid slice">
          <path d="M120 300 C 320 180, 520 220, 720 300 S 1150 380, 1330 260" stroke="#0B0B0B" stroke-opacity="0.12" stroke-width="2" />
          <path class="animate-dash" d="M180 620 C 420 700, 760 560, 1000 640 S 1280 700, 1380 620" stroke="#0B0B0B" stroke-opacity="0.35" stroke-width="2" stroke-dasharray="8 10" />
          <path class="animate-dash" d="M100 260 C 360 340, 680 200, 980 280 S 1300 340, 1400 300" stroke="#FFFFFF" stroke-opacity="0.8" stroke-width="2" stroke-dasharray="4 12" style="animation-delay:-6s" />
        </svg>
      </div>

      <!-- Tarjetas flotantes con parallax -->
      <div class="pointer-events-none absolute left-[7%] top-[27%] hidden lg:block" data-depth="26" aria-hidden="true">
        <div class="animate-float" style="--r:-6deg">
          <div class="grid h-16 w-16 place-items-center border-4 border-ink bg-white">
            <svg class="h-7 w-7 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.bolt} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute right-[8%] top-[24%] hidden lg:block" data-depth="38" aria-hidden="true">
        <div class="animate-float" style="--r:5deg; --fd:-2s">
          <div class="grid h-16 w-16 place-items-center bg-ink">
            <svg class="h-7 w-7 text-yellow" viewBox="0 0 24 24" fill="currentColor"><path d={iconPaths.whatsapp} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute bottom-[20%] left-[13%] hidden lg:block" data-depth="18" aria-hidden="true">
        <div class="animate-float" style="--r:4deg; --fd:-4s">
          <div class="grid h-14 w-14 place-items-center border-4 border-ink bg-white">
            <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.mail} /></svg>
          </div>
        </div>
      </div>
      <div class="pointer-events-none absolute bottom-[26%] right-[11%] hidden lg:block" data-depth="30" aria-hidden="true">
        <div class="animate-float" style="--r:-4deg; --fd:-5s">
          <div class="grid h-14 w-14 place-items-center border-4 border-ink bg-white">
            <svg class="h-6 w-6 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.cart} /></svg>
          </div>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-6xl text-center">
        <p class="reveal mb-8 inline-flex items-center gap-2 border-2 border-ink bg-white px-4 py-1.5 text-xs font-extrabold uppercase tracking-wider text-ink">
          <span class="inline-block h-2 w-2 animate-pulse bg-ink" aria-hidden="true"></span>
          Promo de lanzamiento: precio especial para los primeros 10 clientes
        </p>
        <h1 class="reveal mx-auto max-w-5xl text-5xl uppercase leading-[0.95] text-ink sm:text-7xl md:text-8xl" style="--d:.1s">
          Tu negocio en internet, <span class="inline-block bg-ink px-3 text-brand">todo incluido</span>, sin letra pequeña
        </h1>
        <p class="reveal mx-auto mt-8 max-w-2xl text-lg font-medium leading-relaxed text-ink/80" style="--d:.2s">
          Páginas web desde <strong class="text-ink">$390.000</strong>, bots de WhatsApp con inteligencia
          artificial que venden por ti 24/7, correo corporativo y automatizaciones. Dominio, hosting,
          SSL y soporte <strong class="text-ink">incluidos en un solo precio</strong>.
        </p>
        <div class="reveal mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" style="--d:.3s">
          <a
            href={wa('Hola DeOne Labs, quiero cotizar mi página web')}
            target="_blank"
            rel="noopener"
            class="btn btn-dark btn-ripple inline-flex items-center gap-2 rounded-2xl bg-ink px-8 py-4 text-base font-bold text-white"
          >
            <svg class="h-5 w-5 text-yellow" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={iconPaths.whatsapp}></path></svg>
            Cotiza gratis por WhatsApp
          </a>
          <a
            href="#servicios"
            class="btn btn-ripple rounded-2xl border-2 border-ink bg-white px-8 py-4 text-base font-bold text-ink"
          >
            Ver precios
          </a>
        </div>
        <dl class="mx-auto mt-16 grid max-w-4xl grid-cols-1 gap-0 sm:grid-cols-3">
          <div class="reveal bg-ink p-6 text-left" style="--d:.4s">
            <dt class="text-xs font-bold uppercase tracking-widest text-white/60">Entrega de tu página</dt>
            <dd class="mt-2 font-heading text-3xl uppercase text-yellow">5–7 días</dd>
          </div>
          <div class="reveal border-4 border-ink bg-white p-6 text-left" style="--d:.5s">
            <dt class="text-xs font-bold uppercase tracking-widest text-mid">Costos escondidos</dt>
            <dd class="mt-2 font-heading text-3xl uppercase text-ink">Cero</dd>
          </div>
          <div class="reveal bg-paper p-6 text-left" style="--d:.6s">
            <dt class="text-xs font-bold uppercase tracking-widest text-mid">Si no te gusta el diseño</dt>
            <dd class="mt-2 font-heading text-3xl uppercase leading-none text-ink">Te devolvemos la plata</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- Servicios: bloque negro -->
    <section id="servicios" class="scroll-mt-20 bg-ink px-4 py-24">
      <div class="mx-auto max-w-6xl">
        <h2 class="reveal bar-under bar-center text-center text-4xl uppercase leading-tight text-white md:text-6xl">
          Servicios y precios <span class="inline-block bg-brand px-3 text-ink">claros</span>
        </h2>
        <p class="reveal mx-auto mt-8 max-w-2xl text-center font-medium leading-relaxed text-gray-300" style="--d:.1s">
          Un solo precio con todo incluido. Compara con lo que cobra el mercado y decide tú mismo.
        </p>
        <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            servicios.map((s, i) => (
              <article
                class={`reveal card-lift relative flex flex-col p-7 ${
                  s.destacado ? 'bg-brand text-ink' : 'bg-white text-ink'
                }`}
                style={`--d:${(i % 3) * 0.1}s; --sc:${s.destacado ? '#ffffff' : '#FFD600'}`}
              >
                {s.destacado && (
                  <p class="absolute -top-4 left-1/2 -translate-x-1/2 whitespace-nowrap bg-ink px-4 py-1.5 text-xs font-extrabold uppercase tracking-widest text-brand">
                    El favorito
                  </p>
                )}
                <div class={`grid h-14 w-14 place-items-center ${s.destacado ? 'bg-ink text-brand' : 'bg-brand text-ink'}`}>
                  <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={iconPaths[s.icon]} />
                  </svg>
                </div>
                <h3 class="mt-5 text-2xl uppercase tracking-wide">{s.nombre}</h3>
                <p class="mt-2 text-sm font-medium leading-relaxed text-ink/70">{s.desc}</p>
                <p class="mt-6 font-heading text-4xl uppercase leading-none">{s.precio}</p>
                <p class="mt-2 w-fit bg-ink px-2.5 py-1 text-xs font-extrabold uppercase tracking-wider text-brand">{s.mes}</p>
                <p class="mt-2 text-xs font-semibold text-ink/50">{s.mercado}</p>
                <ul class="mt-6 space-y-2.5 text-sm font-semibold text-ink/85">
                  {s.incluye.map((item) => (
                    <li class="flex items-start gap-2.5">
                      <span class={`mt-0.5 grid h-4.5 w-4.5 shrink-0 place-items-center ${s.destacado ? 'bg-ink text-brand' : 'bg-brand text-ink'}`} aria-hidden="true">
                        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                          <path d={iconPaths.check} />
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
                <a
                  href={wa(`Hola DeOne Labs, me interesa: ${s.nombre}`)}
                  target="_blank"
                  rel="noopener"
                  class={`btn btn-dark btn-ripple mt-7 rounded-2xl px-5 py-3 text-center text-sm font-bold ${
                    s.destacado ? 'bg-ink text-brand' : 'bg-ink text-white'
                  }`}
                >
                  Lo quiero
                </a>
              </article>
            ))
          }
        </div>
        <p class="reveal mt-10 text-center text-sm font-bold uppercase tracking-wider text-gray-400">
          Pago fácil: 50% para iniciar y 50% contra entrega · Nequi o Bancolombia · Sin permanencia
        </p>
      </div>
    </section>

    <!-- Bot estrella: bloque partido negro / amarillo -->
    <section id="bot" class="scroll-mt-20">
      <div class="grid lg:grid-cols-2">
        <div class="flex items-center bg-ink px-5 py-16 md:px-14">
          <div class="mx-auto max-w-xl lg:mx-0 lg:ml-auto lg:max-w-[34rem] lg:pr-6">
            <p class="reveal mb-6 inline-flex items-center gap-2 border-2 border-yellow px-4 py-1.5 text-xs font-extrabold uppercase tracking-widest text-yellow">
              <span class="inline-block h-2 w-2 animate-pulse bg-yellow" aria-hidden="true"></span>
              Producto estrella
            </p>
            <h2 class="reveal text-4xl uppercase leading-[1.02] text-white md:text-5xl">
              Un empleado que atiende tu WhatsApp <span class="text-yellow">24 horas</span> y nunca pide vacaciones
            </h2>
            <p class="reveal mt-6 font-medium leading-relaxed text-gray-300" style="--d:.1s">
              Nuestro bot con inteligencia artificial responde a tus clientes al instante, toma pedidos,
              agenda citas, responde preguntas de tu negocio y te pasa la conversación cuando de verdad
              se necesita una persona.
            </p>
            <ul class="reveal mt-7 space-y-3.5 text-gray-200" style="--d:.15s">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center bg-yellow" aria-hidden="true">
                  <svg class="h-3.5 w-3.5 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.check} /></svg>
                </span>
                <span><strong class="text-white">Sin costo por mensaje.</strong> Otros te cobran cada conversación; con nosotros es plano.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center bg-yellow" aria-hidden="true">
                  <svg class="h-3.5 w-3.5 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d={iconPaths.check} /></svg>
                </span>
                <span><strong class="text-white">IA entrenada con tu negocio:</strong> precios, horarios, productos y preguntas frecuentes.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 grid h-5 w-5 shrink-0 place-items-center bg-yellow" aria-hidden="true">
