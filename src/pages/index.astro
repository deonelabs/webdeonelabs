                <div class="faq-panel" id={`faq-panel-${i}`} role="region" aria-labelledby={`faq-trigger-${i}`}>
                  <div>
                    <p class="px-6 pb-6 font-medium leading-relaxed text-ink/70" data-es={f.a} data-en={f.aEN}>{f.a}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA final: bloque crema -->
    <section class="relative overflow-hidden bg-paper px-4 py-24">
      <p class="pointer-events-none absolute -bottom-14 -right-4 select-none font-heading text-[13rem] leading-none text-ink/5" aria-hidden="true">DO</p>
      <div class="relative mx-auto max-w-4xl text-center">
        <h2 class="reveal text-4xl uppercase leading-[1.02] text-ink md:text-6xl" data-es="Hablemos de tu negocio, sin compromiso" data-en="Let's talk about your business, no strings attached">
          Hablemos de tu negocio, sin compromiso
        </h2>
        <p class="reveal mx-auto mt-6 max-w-xl font-medium leading-relaxed text-ink/70" style="--d:.1s"
          data-es="Cuéntanos qué necesitas y en menos de 24 horas te mandamos una propuesta con precio cerrado. La cotización es gratis y no te compromete a nada."
          data-en="Tell us what you need and within 24 hours we'll send you a proposal with a fixed price. The quote is free and comes with no obligation."
        >
          Cuéntanos qué necesitas y en menos de 24 horas te mandamos una propuesta con precio cerrado.
          La cotización es gratis y no te compromete a nada.
        </p>
        <a
          href={wa('Hola DeOne Labs, quiero una cotización gratis para mi negocio')}
          target="_blank"
          rel="noopener"
          class="btn btn-dark btn-ripple reveal mt-10 inline-flex items-center gap-3 rounded-2xl bg-ink px-10 py-5 text-lg font-bold text-brand"
          style="--d:.2s"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={iconPaths.whatsapp}></path></svg>
          <span data-es="Cotizar gratis por WhatsApp" data-en="Get a free quote on WhatsApp">Cotizar gratis por WhatsApp</span>
        </a>
      </div>
    </section>

    <!-- Footer: barra negra delgada -->
    <footer class="bg-ink px-4 py-8">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-5 text-xs font-bold uppercase tracking-widest text-gray-400 md:flex-row">
        <p class="flex items-center gap-2.5 font-heading text-base uppercase text-white">
          <span class="grid h-8 w-8 place-items-center bg-brand font-heading text-xs text-ink" aria-hidden="true">DO</span>
          DeOne Labs
        </p>
        <p class="text-center normal-case" data-es="Páginas web · Bots con IA · Correo corporativo · Automatizaciones" data-en="Websites · AI Bots · Corporate Email · Automations">Páginas web · Bots con IA · Correo corporativo · Automatizaciones</p>
        <p class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 bg-brand" aria-hidden="true"></span>
          <span data-es="Colombia" data-en="Colombia">Colombia</span> · {new Date().getFullYear()}
        </p>
      </div>
    </footer>

    <script>
      // Animaciones siempre activas (decisión de la marca): Windows con las
      // animaciones del sistema apagadas activa prefers-reduced-motion solo,
      // y eso dejaba la web sin cortina, sin reveals y con scroll cortado.
      const reduced = false;

      /* ---- Idioma (ES/EN) y moneda (COP/USD): toggles persistidos en localStorage ---- */
      const LANG_KEY = 'do-lang';
      const CUR_KEY = 'do-currency';

      function applyLang(lang) {
        document.documentElement.lang = lang === 'en' ? 'en' : 'es';
        document.querySelectorAll('[data-es]').forEach((el) => {
          const next = lang === 'en' ? el.dataset.en : el.dataset.es;
          if (next != null) el.textContent = next;
        });
        document.querySelectorAll('[data-es-html]').forEach((el) => {
          const next = lang === 'en' ? el.dataset.enHtml : el.dataset.esHtml;
          if (next != null) el.innerHTML = next;
        });
        const label = document.querySelector('[data-lang-label]');
        if (label) label.textContent = lang === 'en' ? 'EN' : 'ES';
        localStorage.setItem(LANG_KEY, lang);
      }

      function applyCurrency(cur) {
        document.querySelectorAll('[data-cop]').forEach((el) => {
          const next = cur === 'usd' ? el.dataset.usd : el.dataset.cop;
          if (next != null) el.textContent = next;
        });
        const label = document.querySelector('[data-currency-label]');
        if (label) label.textContent = cur === 'usd' ? 'USD' : 'COP';
        localStorage.setItem(CUR_KEY, cur);
      }

      const savedLang = localStorage.getItem(LANG_KEY) || 'es';
      const savedCur = localStorage.getItem(CUR_KEY) || 'cop';
      applyLang(savedLang);
      applyCurrency(savedCur);

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        applyLang(document.documentElement.lang === 'en' ? 'es' : 'en');
      });
      document.getElementById('currency-toggle')?.addEventListener('click', () => {
        const current = localStorage.getItem(CUR_KEY) || 'cop';
        applyCurrency(current === 'usd' ? 'cop' : 'usd');
      });

      /* ---- Navbar: encoge al hacer scroll y se oculta al bajar ---- */
      const nav = document.getElementById('site-nav');
      const header = document.getElementById('site-header');
      const canHover = window.matchMedia('(hover: hover)').matches;
      let lastY = window.scrollY;
      const onScroll = () => {
        const y = window.scrollY;
        nav.classList.toggle('nav-small', y > 24);
        if (y <= 80) {
          // Cerca del inicio siempre visible
          header.classList.remove('nav-hidden');
        } else if (y > lastY + 4 && y > 140) {
          // Bajando: se oculta
          header.classList.add('nav-hidden');
        } else if (!canHover && y < lastY - 6) {
          // En táctil (sin mouse) reaparece al subir
          header.classList.remove('nav-hidden');
        }
        lastY = y;
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Reaparece al pasar el mouse por la parte superior de la página
      document.addEventListener('mousemove', (e) => {
        if (e.clientY < 90) header.classList.remove('nav-hidden');
      });
      // Y al navegar con teclado hacia el menú
      header.addEventListener('focusin', () => header.classList.remove('nav-hidden'));

      /* ---- Scroll fluido en todos los atajos (#anclas) ----
         Animación propia con requestAnimationFrame: no depende del
         scroll suave nativo del navegador (que puede saltar de golpe). */
      let scrollAnim = null;
      const cancelScrollAnim = () => {
        if (scrollAnim) {
          cancelAnimationFrame(scrollAnim);
          scrollAnim = null;
        }
      };
      window.addEventListener('wheel', cancelScrollAnim, { passive: true });
      window.addEventListener('touchstart', cancelScrollAnim, { passive: true });

      const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      const smoothScrollTo = (targetY) => {
        cancelScrollAnim();
        const startY = window.scrollY;
        const diff = targetY - startY;
        if (Math.abs(diff) < 2) return;
        // Duración proporcional a la distancia, entre 500ms y 1100ms
        const duration = Math.min(1100, Math.max(500, Math.abs(diff) * 0.35));
        let start;
        const step = (ts) => {
          if (start === undefined) start = ts;
          const p = Math.min((ts - start) / duration, 1);
          window.scrollTo(0, startY + diff * easeInOutCubic(p));
          scrollAnim = p < 1 ? requestAnimationFrame(step) : null;
        };
        scrollAnim = requestAnimationFrame(step);
      };

      const NAV_OFFSET = 84; // espacio para el navbar fijo
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = a.getAttribute('href').slice(1);
          const target = id ? document.getElementById(id) : null;
          if (id && !target) return;
          e.preventDefault();
          const top = target
            ? target.getBoundingClientRect().top + window.scrollY - NAV_OFFSET
            : 0;
          smoothScrollTo(Math.max(0, top));
          history.pushState(null, '', id ? `#${id}` : window.location.pathname);
        });
      });

      /* ---- Scroll reveal (arranca cuando la cortina abre) ---- */
      const startReveals = () => {
        const revealEls = document.querySelectorAll('.reveal');
        if (reduced) {
          revealEls.forEach((el) => el.classList.add('revealed'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('revealed');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      };

      /* ---- Cortina de entrada (en cada carga de la página) ---- */
      const curtain = document.getElementById('curtain');
      if (curtain) {
        document.body.style.overflow = 'hidden';
        const HOLD = reduced ? 150 : 1600; // tiempo mostrando la imagen de marca
        setTimeout(() => {
          curtain.classList.add('open');
          setTimeout(
            () => {
              curtain.remove();
              document.body.style.overflow = '';
              startReveals();
            },
            reduced ? 50 : 1000
          );
        }, HOLD);
      } else {
        startReveals();
      }

      /* ---- Parallax suave en el hero ---- */
      const hero = document.getElementById('hero');
      const layers = document.querySelectorAll('[data-depth]');
      if (hero && !reduced && window.matchMedia('(pointer: fine)').matches) {
        hero.addEventListener('mousemove', (e) => {
          const r = hero.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          layers.forEach((l) => {
            const d = Number(l.dataset.depth);
            l.style.transform = `translate(${(-x * d).toFixed(1)}px, ${(-y * d).toFixed(1)}px)`;
          });
        });
      }

      /* ---- Ripple en botones ---- */
      document.querySelectorAll('.btn-ripple').forEach((btn) => {
        btn.addEventListener('pointerdown', (e) => {
          const r = btn.getBoundingClientRect();
          const s = document.createElement('span');
          const size = Math.max(r.width, r.height) * 2;
          // Ripple oscuro sobre fondos claros, claro sobre fondo negro
          const light = btn.classList.contains('bg-ink');
          s.className = 'ripple' + (light ? '' : ' ripple-dark');
          s.style.width = s.style.height = `${size}px`;
          s.style.left = `${e.clientX - r.left - size / 2}px`;
          s.style.top = `${e.clientY - r.top - size / 2}px`;
          btn.appendChild(s);
          setTimeout(() => s.remove(), 700);
        });
      });

      /* ---- Acordeones FAQ ---- */
      const faqItems = document.querySelectorAll('.faq-item');
      faqItems.forEach((item) => {
        const btn = item.querySelector('.faq-trigger');
        btn.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          faqItems.forEach((other) => {
            other.classList.remove('open');
            other.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      /* ---- Chat animado del bot ---- */
      const chatBox = document.getElementById('chat-demo');
      if (chatBox) {
        const msgs = [...chatBox.querySelectorAll('[data-msg]')];
        const note = chatBox.querySelector('[data-chat-note]');
        const typing = chatBox.querySelector('#chat-typing');
        const scrollArea = chatBox.querySelector('#chat-scroll');
        const scrollDown = () => {
          scrollArea.scrollTo({ top: scrollArea.scrollHeight, behavior: 'smooth' });
        };
        const wait = (ms) => new Promise((r) => setTimeout(r, ms));

        const play = async () => {
          await wait(600);
          for (const m of msgs) {
            if (m.dataset.msg === 'bot') {
              m.before(typing);
              typing.classList.remove('is-hidden');
              typing.classList.add('msg-in');
              scrollDown();
              await wait(1500);
              typing.classList.add('is-hidden');
            }
            m.classList.remove('is-hidden');
            m.classList.add('msg-in');
            scrollDown();
            await wait(m.dataset.msg === 'bot' ? 1000 : 1200);
          }
          typing.remove();
          note.classList.remove('is-hidden');
          note.classList.add('msg-in');
          scrollDown();
        };

        if (reduced) {
          msgs.forEach((m) => m.classList.remove('is-hidden'));
          note.classList.remove('is-hidden');
          typing.remove();
        } else {
          const co = new IntersectionObserver(
            (entries) => {
              if (entries.some((e) => e.isIntersecting)) {
                co.disconnect();
                play();
              }
            },
            { threshold: 0.45 }
          );
          co.observe(chatBox);
        }
      }
    </script>
  </body>
</html>
