    <script>
      // Animaciones siempre activas (decisión de la marca): Windows con las
      // animaciones del sistema apagadas activa prefers-reduced-motion solo,
      // y eso dejaba la web sin cortina, sin reveals y con scroll cortado.
      const reduced = false;

      /* ---- Navbar: encoge al hacer scroll y se oculta al bajar ---- */
      const nav = document.getElementById('site-nav');
      const header = document.getElementById('site-header');
      const canHover = window.matchMedia('(hover: hover)').matches;
      let lastY = window.scrollY;
      const onScroll = () => {
        const y = window.scrollY;
        nav.classList.toggle('nav-small', y > 24);
        if (y <= 80) {
          // Cerca del inicio siempre visible
          header.classList.remove('nav-hidden');
        } else if (y > lastY + 4 && y > 140) {
          // Bajando: se oculta
          header.classList.add('nav-hidden');
        } else if (!canHover && y < lastY - 6) {
          // En táctil (sin mouse) reaparece al subir
          header.classList.remove('nav-hidden');
        }
        lastY = y;
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Reaparece al pasar el mouse por la parte superior de la página
      document.addEventListener('mousemove', (e) => {
        if (e.clientY < 90) header.classList.remove('nav-hidden');
      });
      // Y al navegar con teclado hacia el menú
      header.addEventListener('focusin', () => header.classList.remove('nav-hidden'));

      /* ---- Scroll fluido en todos los atajos (#anclas) ----
         Animación propia con requestAnimationFrame: no depende del
         scroll suave nativo del navegador (que puede saltar de golpe). */
      let scrollAnim = null;
      const cancelScrollAnim = () => {
        if (scrollAnim) {
          cancelAnimationFrame(scrollAnim);
          scrollAnim = null;
        }
      };
      window.addEventListener('wheel', cancelScrollAnim, { passive: true });
      window.addEventListener('touchstart', cancelScrollAnim, { passive: true });

      const easeInOutCubic = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

      const smoothScrollTo = (targetY) => {
        cancelScrollAnim();
        const startY = window.scrollY;
        const diff = targetY - startY;
        if (Math.abs(diff) < 2) return;
        // Duración proporcional a la distancia, entre 500ms y 1100ms
        const duration = Math.min(1100, Math.max(500, Math.abs(diff) * 0.35));
        let start;
        const step = (ts) => {
          if (start === undefined) start = ts;
          const p = Math.min((ts - start) / duration, 1);
          window.scrollTo(0, startY + diff * easeInOutCubic(p));
          scrollAnim = p < 1 ? requestAnimationFrame(step) : null;
        };
        scrollAnim = requestAnimationFrame(step);
      };

      const NAV_OFFSET = 84; // espacio para el navbar fijo
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = a.getAttribute('href').slice(1);
          const target = id ? document.getElementById(id) : null;
          if (id && !target) return;
          e.preventDefault();
          const top = target
            ? target.getBoundingClientRect().top + window.scrollY - NAV_OFFSET
            : 0;
          smoothScrollTo(Math.max(0, top));
          history.pushState(null, '', id ? `#${id}` : window.location.pathname);
        });
      });

      /* ---- Scroll reveal (arranca cuando la cortina abre) ---- */
      const startReveals = () => {
        const revealEls = document.querySelectorAll('.reveal');
        if (reduced) {
          revealEls.forEach((el) => el.classList.add('revealed'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('revealed');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        revealEls.forEach((el) => io.observe(el));
      };

      /* ---- Cortina de entrada (en cada carga de la página) ---- */
      const curtain = document.getElementById('curtain');
      if (curtain) {
        document.body.style.overflow = 'hidden';
        const HOLD = reduced ? 150 : 1600; // tiempo mostrando la imagen de marca
        setTimeout(() => {
          curtain.classList.add('open');
          setTimeout(
            () => {
              curtain.remove();
              document.body.style.overflow = '';
              startReveals();
            },
            reduced ? 50 : 1000
          );
        }, HOLD);
      } else {
        startReveals();
      }

      /* ---- Parallax suave en el hero ---- */
      const hero = document.getElementById('hero');
      const layers = document.querySelectorAll('[data-depth]');
      if (hero && !reduced && window.matchMedia('(pointer: fine)').matches) {
        hero.addEventListener('mousemove', (e) => {
          const r = hero.getBoundingClientRect();
          const x = (e.clientX - r.left) / r.width - 0.5;
          const y = (e.clientY - r.top) / r.height - 0.5;
          layers.forEach((l) => {
            const d = Number(l.dataset.depth);
            l.style.transform = `translate(${(-x * d).toFixed(1)}px, ${(-y * d).toFixed(1)}px)`;
          });
        });
      }

      /* ---- Ripple en botones ---- */
      document.querySelectorAll('.btn-ripple').forEach((btn) => {
        btn.addEventListener('pointerdown', (e) => {
          const r = btn.getBoundingClientRect();
          const s = document.createElement('span');
          const size = Math.max(r.width, r.height) * 2;
          // Ripple oscuro sobre fondos claros, claro sobre fondo negro
          const light = btn.classList.contains('bg-ink');
          s.className = 'ripple' + (light ? '' : ' ripple-dark');
          s.style.width = s.style.height = `${size}px`;
          s.style.left = `${e.clientX - r.left - size / 2}px`;
          s.style.top = `${e.clientY - r.top - size / 2}px`;
          btn.appendChild(s);
          setTimeout(() => s.remove(), 700);
        });
      });

      /* ---- Acordeones FAQ ---- */
      const faqItems = document.querySelectorAll('.faq-item');
      faqItems.forEach((item) => {
        const btn = item.querySelector('.faq-trigger');
        btn.addEventListener('click', () => {
          const isOpen = item.classList.contains('open');
          faqItems.forEach((other) => {
            other.classList.remove('open');
            other.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      /* ---- Chat animado del bot ---- */
      const chatBox = document.getElementById('chat-demo');
      if (chatBox) {
        const msgs = [...chatBox.querySelectorAll('[data-msg]')];
        const note = chatBox.querySelector('[data-chat-note]');
        const typing = chatBox.querySelector('#chat-typing');
        const scrollArea = chatBox.querySelector('#chat-scroll');
        const scrollDown = () => {
          scrollArea.scrollTo({ top: scrollArea.scrollHeight, behavior: 'smooth' });
        };
        const wait = (ms) => new Promise((r) => setTimeout(r, ms));

        const play = async () => {
          await wait(600);
          for (const m of msgs) {
            if (m.dataset.msg === 'bot') {
              m.before(typing);
              typing.classList.remove('is-hidden');
              typing.classList.add('msg-in');
              scrollDown();
              await wait(1500);
              typing.classList.add('is-hidden');
            }
            m.classList.remove('is-hidden');
            m.classList.add('msg-in');
            scrollDown();
            await wait(m.dataset.msg === 'bot' ? 1000 : 1200);
          }
          typing.remove();
          note.classList.remove('is-hidden');
          note.classList.add('msg-in');
          scrollDown();
        };

        if (reduced) {
          msgs.forEach((m) => m.classList.remove('is-hidden'));
          note.classList.remove('is-hidden');
          typing.remove();
        } else {
          const co = new IntersectionObserver(
            (entries) => {
              if (entries.some((e) => e.isIntersecting)) {
                co.disconnect();
                play();
              }
            },
            { threshold: 0.45 }
          );
          co.observe(chatBox);
        }
      }
    </script>
